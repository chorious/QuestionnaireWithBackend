#!/bin/sh
# Auto-bump version on commit

VERSION_FILE="VERSION"
FRONTEND_FILE="src/config/version.ts"
PUBLIC_VERSION="public/version.json"

# Read current version from VERSION file
CURRENT=$(cat "$VERSION_FILE" | tr -d '[:space:]')

if [ -z "$CURRENT" ]; then
    echo "pre-commit: could not read version from $VERSION_FILE, skipping bump"
    exit 0
fi

# Split into parts
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

# Bump patch
PATCH=$((PATCH + 1))
NEW="$MAJOR.$MINOR.$PATCH"

# Update VERSION file
echo "$NEW" > "$VERSION_FILE"

# Update frontend file
sed -i.bak "s/APP_VERSION = '[^']*'/APP_VERSION = '$NEW'/" "$FRONTEND_FILE" && rm -f "$FRONTEND_FILE.bak"

# Generate public/version.json for GitHub Pages deploy tracking
echo "{\"version\": \"$NEW\"}" > "$PUBLIC_VERSION"

git add "$VERSION_FILE" "$FRONTEND_FILE" "$PUBLIC_VERSION"

echo "pre-commit: bumped version $CURRENT -> $NEW"
exit 0
